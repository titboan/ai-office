# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot Tokens (каждый агент — отдельный бот)
MARTA_BOT_TOKEN=your_marta_bot_token_here
KEVIN_BOT_TOKEN=your_kevin_bot_token_here
KASPER_BOT_TOKEN=your_kasper_bot_token_here
PETER_BOT_TOKEN=your_peter_bot_token_here
ELINA_BOT_TOKEN=your_elina_bot_token_here
ALEX_BOT_TOKEN=your_alex_bot_token_here

# Telegram Group (куда все агенты пишут)
OFFICE_GROUP_ID=your_office_group_id_here

# Claude Model
CLAUDE_MODEL=claude-sonnet-4-6

# Веб-поиск для агента Каспер (получить ключ: https://tavily.com)
TAVILY_API_KEY=

# Голосовые сообщения — транскрипция через Groq Whisper (бесплатно)
# Получить ключ: https://console.groq.com → API Keys
GROQ_API_KEY=

# База данных (task queue — очередь задач между агентами)
# Railway: Add Plugin → PostgreSQL → DATABASE_URL подставится автоматически
DATABASE_URL=

# Redis (память агентов — история диалогов)
# Если не задан — история хранится в памяти процесса (теряется при рестарте)
# Railway: добавь плагин Redis → REDIS_URL подставится автоматически
REDIS_URL=

# Webhook (для Railway)
WEBHOOK_BASE_URL=https://your-app.railway.app
PORT=8080

# ── Notion (интеграция для агентов) ───────────────────────────────────────────
# Получить токен: https://www.notion.so/my-integrations → New integration
NOTION_TOKEN=
# ID страницы в Notion, куда setup_notion.py создаст базы данных
# Открой страницу → Share → Copy link → 32 символа в конце URL
NOTION_PARENT_PAGE_ID=

# ID баз данных (заполняются автоматически после запуска setup_notion.py)
NOTION_PROJECTS_DB=
NOTION_TASKS_DB=
NOTION_IDEAS_DB=
NOTION_RESEARCH_DB=
NOTION_CONTENT_DB=

# GitHub (агент Кевин — создаёт репо, коммитит код, открывает PR)
# Получить токен: github.com/settings/tokens → Fine-grained token → repo scope
GITHUB_TOKEN=
GITHUB_USERNAME=

# Push-уведомления через ntfy.sh (бесплатно, нативный iOS/Android пуш)
# 1. Установи приложение ntfy на телефон
# 2. Подпишись на свой уникальный топик (любая строка)
# 3. Задай здесь тот же топик
NTFY_TOPIC=

# ── Макс — отзывы на маркетплейсах ───────────────────────────────────────────
MAX_BOT_TOKEN=
PARTNERS_GROUP_ID=  # ID группы с партнёрами (бот должен быть добавлен с правами отправки)
# WB токен: seller.wildberries.ru → Настройки → Доступ к API → Категория "Отзывы"
# Ozon: seller.ozon.ru → Настройки → API ключи (нужен и Api-Key и Client-Id)

# ── Ева — дайджест Telegram-каналов ──────────────────────────────────────────
# Бот Евы (отдельный от других агентов)
EVA_BOT_TOKEN=
# Получить: my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# StringSession — генерируется один раз через telethon.sessions.StringSession
# Запусти: python -c "from telethon.sync import TelegramClient; from telethon.sessions import StringSession; s=StringSession(); c=TelegramClient(s,API_ID,API_HASH); c.start(); print(c.session.save())"
TELETHON_SESSION=

# ── Ева — Email дайджест ───────────────────────────────────────────────────────
# Ящик 1 (Gmail)
EMAIL_USER=
EMAIL_APP_PASS=  # нужен только для локального запуска (IMAP)

# Ящик 2 (Яндекс)
EMAIL_USER_2=
EMAIL_APP_PASS_2=  # нужен только для локального запуска без YANDEX_REFRESH_TOKEN

# Яндекс OAuth2 (XOAUTH2 для IMAP) — Railway-совместимый вариант
# Получить: python tools/yandex_auth.py
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REFRESH_TOKEN=

# Gmail API (OAuth2) — нужен для Railway вместо IMAP
# Получить: запусти python tools/gmail_auth.py и следуй инструкции
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
